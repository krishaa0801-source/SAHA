PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string (create a free cluster at mongodb.com/atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/saha?retryWrites=true&w=majority

# Long random string used to sign session cookies — generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string
